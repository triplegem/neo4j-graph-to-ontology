
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix kgo: <https://kg.engineering.cornell.edu/ontology#> .
@prefix kgr: <https://kg.engineering.cornell.edu/resource/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .


kgo:CampusShape
    a sh:NodeShape ;
    sh:targetClass kgo:Campus ;
    sh:property [
        sh:path kgo:name ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ]
.

kgo:CollegeShape
    a sh:NodeShape ;
    sh:targetClass kgo:College ;
    sh:property [
        sh:path kgo:name ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ]
.

kgo:ConceptShape
    a sh:NodeShape ;
    sh:targetClass kgo:Concept ;
    sh:property [
        sh:path kgo:identifier ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ]
.

kgo:ConceptSchemeShape
    a sh:NodeShape ;
    sh:targetClass kgo:ConceptScheme ;
    sh:property [
        sh:path kgo:description ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path kgo:identifier ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ]
.

kgo:DepartmentShape
    a sh:NodeShape ;
    sh:targetClass kgo:Department ;
    sh:property [
        sh:path kgo:name ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ]
.

kgo:FacultyShape
    a sh:NodeShape ;
    sh:targetClass kgo:Faculty ;
    sh:property [
        sh:path kgo:email ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path kgo:name ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path kgo:netid ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path kgo:rank ;
        sh:datatype xsd:string ;
        sh:in ( "Associate Professor" "Professor" ) ;
    ]
.

kgo:GrantShape
    a sh:NodeShape ;
    sh:targetClass kgo:Grant ;
    sh:property [
        sh:path kgo:awardNumber ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path kgo:endDate ;
        sh:datatype xsd:date ;
    ] ;
    sh:property [
        sh:path kgo:identifier ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path kgo:sponsor ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path kgo:startDate ;
        sh:datatype xsd:date ;
    ] ;
    sh:property [
        sh:path kgo:title ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ]
.

kgo:ORCIDShape
    a sh:NodeShape ;
    sh:targetClass kgo:ORCID ;
    sh:property [
        sh:path kgo:identifier ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path kgo:uri ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ]
.

kgo:PublicationShape
    a sh:NodeShape ;
    sh:targetClass kgo:Publication ;
    sh:property [
        sh:path kgo:datePublished ;
        sh:datatype xsd:date ;
    ] ;
    sh:property [
        sh:path kgo:identifier ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path kgo:title ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path kgo:uri ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path kgo:venue ;
        sh:datatype xsd:string ;
    ]
.

kgo:UniversityShape
    a sh:NodeShape ;
    sh:targetClass kgo:University ;
    sh:property [
        sh:path kgo:name ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ]
.

kgo:WikidataShape
    a sh:NodeShape ;
    sh:targetClass kgo:Wikidata ;
    sh:property [
        sh:path kgo:identifier ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path kgo:uri ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ]
.
