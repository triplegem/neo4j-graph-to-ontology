@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix kgo: <https://kg.engineering.cornell.edu/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

kgo: a owl:Ontology ;
    rdfs:label "Cornell Engineering Faculty Expertise Ontology" ;
    dcterms:created "2026-07-21"^^xsd:date ;
    dcterms:creator "Chris Lastovicka" ;
    dcterms:title "Faculty Expertise Ontology" ;
    rdfs:comment "Ontology supporting an engineering faculty expertise knowledge graph." ;
    owl:versionInfo "1.0" .

kgo:College a owl:Class ;
    rdfs:label "College" ;
    rdfs:comment "An academic college." ;
    rdfs:subClassOf schema:CollegeOrUniversity .

kgo:ORCID a owl:Class ;
    rdfs:label "ORCID" ;
    rdfs:comment "An ORCID identifier resource." .

kgo:University a owl:Class ;
    rdfs:label "University" ;
    rdfs:comment "A university." ;
    rdfs:subClassOf schema:CollegeOrUniversity .

kgo:Wikidata a owl:Class ;
    rdfs:label "Wikidata" ;
    rdfs:comment "A Wikidata entity." .

kgo:about a owl:ObjectProperty ;
    rdfs:label "about" ;
    rdfs:comment "Associates a publication or grant with a research topic." ;
    rdfs:range kgo:Concept .

kgo:awardNumber a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "award number" ;
    rdfs:comment "Ontology property 'award number'." ;
    rdfs:domain kgo:Grant ;
    rdfs:range xsd:string .

kgo:datePublished a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "date published" ;
    rdfs:comment "Ontology property 'date published'." ;
    rdfs:domain kgo:Publication ;
    rdfs:range xsd:date .

kgo:description a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "description" ;
    rdfs:comment "Ontology property 'description'." ;
    rdfs:domain kgo:ConceptScheme ;
    rdfs:range xsd:string .

kgo:email a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "email" ;
    rdfs:comment "Ontology property 'email'." ;
    rdfs:domain kgo:Faculty ;
    rdfs:range xsd:string .

kgo:endDate a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "end date" ;
    rdfs:comment "Ontology property 'end date'." ;
    rdfs:domain kgo:Grant ;
    rdfs:range xsd:date .

kgo:identifier a owl:DatatypeProperty ;
    rdfs:label "identifier" ;
    rdfs:comment "Unique identifier for the resource." ;
    rdfs:range xsd:string .

kgo:knowsAbout a owl:ObjectProperty ;
    rdfs:label "knows about" ;
    rdfs:comment "Relates a faculty member to an area of expertise." ;
    rdfs:domain kgo:Faculty ;
    rdfs:range kgo:Concept .

kgo:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:comment "Human-readable name of the resource." ;
    rdfs:range xsd:string .

kgo:netid a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "netid" ;
    rdfs:comment "Ontology property 'netid'." ;
    rdfs:domain kgo:Faculty ;
    rdfs:range xsd:string .

kgo:rank a owl:DatatypeProperty ;
    rdfs:label "rank" ;
    rdfs:comment "Ontology property 'rank'." ;
    rdfs:domain kgo:Faculty ;
    rdfs:range xsd:string .

kgo:sponsor a owl:DatatypeProperty ;
    rdfs:label "sponsor" ;
    rdfs:comment "Ontology property 'sponsor'." ;
    rdfs:domain kgo:Grant ;
    rdfs:range xsd:string .

kgo:startDate a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "start date" ;
    rdfs:comment "Ontology property 'start date'." ;
    rdfs:domain kgo:Grant ;
    rdfs:range xsd:date .

kgo:title a owl:DatatypeProperty ;
    rdfs:label "title" ;
    rdfs:comment "Title of the resource." ;
    rdfs:range xsd:string .

kgo:uri a owl:DatatypeProperty ;
    rdfs:label "uri" ;
    rdfs:comment "Canonical URI identifying the resource." ;
    rdfs:range xsd:anyURI .

kgo:venue a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "venue" ;
    rdfs:comment "Ontology property 'venue'." ;
    rdfs:domain kgo:Publication ;
    rdfs:range xsd:string .

kgo:Campus a owl:Class ;
    rdfs:label "Campus" ;
    rdfs:comment "A physical campus location." ;
    rdfs:subClassOf schema:Place .

kgo:ConceptScheme a owl:Class ;
    rdfs:label "ConceptScheme" ;
    rdfs:comment "A controlled vocabulary of research concepts." ;
    rdfs:subClassOf skos:ConceptScheme .

kgo:Department a owl:Class ;
    rdfs:label "Department" ;
    rdfs:comment "An academic department within the university." ;
    rdfs:subClassOf schema:Organization .

kgo:affiliatedWith a owl:ObjectProperty ;
    rdfs:label "affiliated with" ;
    rdfs:comment "Relates a faculty member to an academic department." ;
    rdfs:domain kgo:Faculty ;
    rdfs:range kgo:Department ;
    owl:inverseOf kgo:hasFaculty .

kgo:authorOf a owl:ObjectProperty ;
    rdfs:label "author of" ;
    rdfs:comment "Relates a faculty member to a publication." ;
    rdfs:domain kgo:Faculty ;
    rdfs:range kgo:Publication ;
    owl:inverseOf kgo:hasAuthor .

kgo:hasAuthor a owl:ObjectProperty ;
    rdfs:label "has author" ;
    rdfs:comment "Inverse of authorOf." ;
    owl:inverseOf kgo:authorOf .

kgo:hasFaculty a owl:ObjectProperty ;
    rdfs:label "has faculty" ;
    rdfs:comment "Inverse of affiliatedWith." ;
    owl:inverseOf kgo:affiliatedWith .

kgo:hasInvestigator a owl:ObjectProperty ;
    rdfs:label "has investigator" ;
    rdfs:comment "Inverse of investigatorOn." ;
    owl:inverseOf kgo:investigatorOn .

kgo:hasLocation a owl:ObjectProperty ;
    rdfs:label "has location" ;
    rdfs:comment "Associates an entity with a campus." ;
    rdfs:range kgo:Campus ;
    owl:inverseOf kgo:locationOf .

kgo:hasSubOrganization a owl:ObjectProperty ;
    rdfs:label "has sub organization" ;
    rdfs:comment "Inverse of subOrganization." ;
    owl:inverseOf kgo:subOrganization .

kgo:investigatorOn a owl:ObjectProperty ;
    rdfs:label "investigator on" ;
    rdfs:comment "Relates a faculty member to a research grant." ;
    rdfs:domain kgo:Faculty ;
    rdfs:range kgo:Grant ;
    owl:inverseOf kgo:hasInvestigator .

kgo:locationOf a owl:ObjectProperty ;
    rdfs:label "location of" ;
    rdfs:comment "Inverse of hasLocation." ;
    owl:inverseOf kgo:hasLocation .

kgo:subOrganization a owl:ObjectProperty ;
    rdfs:label "sub organization" ;
    rdfs:comment "Relates an organization to one of its sub-organizations." ;
    owl:inverseOf kgo:hasSubOrganization .

kgo:Concept a owl:Class ;
    rdfs:label "Concept" ;
    rdfs:comment "A research topic or area of expertise." ;
    rdfs:subClassOf skos:Concept .

kgo:Publication a owl:Class ;
    rdfs:label "Publication" ;
    rdfs:comment "A scholarly publication." ;
    rdfs:subClassOf schema:ScholarlyArticle .

kgo:Grant a owl:Class ;
    rdfs:label "Grant" ;
    rdfs:comment "A sponsored research award." .

kgo:Faculty a owl:Class ;
    rdfs:label "Faculty" ;
    rdfs:comment "A faculty member within the College of Engineering." ;
    rdfs:subClassOf schema:Person .

