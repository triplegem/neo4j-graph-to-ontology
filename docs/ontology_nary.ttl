@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix kgo: <https://kg.engineering.cornell.edu/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

kgo: a owl:Ontology ;
    rdfs:label "Cornell Engineering Faculty Expertise Ontology" ;
    dcterms:created "2026-07-22"^^xsd:date ;
    dcterms:creator "Chris Lastovicka" ;
    dcterms:title "Faculty Expertise Ontology" ;
    rdfs:comment "Ontology supporting an engineering faculty expertise knowledge graph." ;
    owl:versionInfo "1.0" .

kgo:AboutRelationship a owl:Class ;
    rdfs:label "about relationship" ;
    rdfs:comment "Represents a ABOUT relationship." ;
    rdfs:subClassOf kgo:Relationship .

kgo:AffiliatedWithRelationship a owl:Class ;
    rdfs:label "affiliated with relationship" ;
    rdfs:comment "Represents a AFFILIATED_WITH relationship." ;
    rdfs:subClassOf kgo:Relationship .

kgo:AuthorOfRelationship a owl:Class ;
    rdfs:label "author of relationship" ;
    rdfs:comment "Represents a AUTHOR_OF relationship." ;
    rdfs:subClassOf kgo:Relationship .

kgo:BroaderRelationship a owl:Class ;
    rdfs:label "broader relationship" ;
    rdfs:comment "Represents a BROADER relationship." ;
    rdfs:subClassOf kgo:Relationship .

kgo:Campus a owl:Class ;
    rdfs:label "Campus" ;
    rdfs:comment "A physical campus location." ;
    rdfs:subClassOf kgo:Entity,
        schema:Place .

kgo:College a owl:Class ;
    rdfs:label "College" ;
    rdfs:comment "An academic college." ;
    rdfs:subClassOf kgo:Entity,
        schema:CollegeOrUniversity .

kgo:Concept a owl:Class ;
    rdfs:label "Concept" ;
    rdfs:comment "A research topic or area of expertise." ;
    rdfs:subClassOf skos:Concept,
        kgo:Entity .

kgo:Department a owl:Class ;
    rdfs:label "Department" ;
    rdfs:comment "An academic department within the university." ;
    rdfs:subClassOf kgo:Entity,
        schema:Organization .

kgo:ExactMatchRelationship a owl:Class ;
    rdfs:label "exact match relationship" ;
    rdfs:comment "Represents a EXACT_MATCH relationship." ;
    rdfs:subClassOf kgo:Relationship .

kgo:HasLocationRelationship a owl:Class ;
    rdfs:label "has location relationship" ;
    rdfs:comment "Represents a HAS_LOCATION relationship." ;
    rdfs:subClassOf kgo:Relationship .

kgo:InSchemeRelationship a owl:Class ;
    rdfs:label "in scheme relationship" ;
    rdfs:comment "Represents a IN_SCHEME relationship." ;
    rdfs:subClassOf kgo:Relationship .

kgo:InvestigatorOnRelationship a owl:Class ;
    rdfs:label "investigator on relationship" ;
    rdfs:comment "Represents a INVESTIGATOR_ON relationship." ;
    rdfs:subClassOf kgo:Relationship .

kgo:KnowsAboutRelationship a owl:Class ;
    rdfs:label "knows about relationship" ;
    rdfs:comment "Represents a KNOWS_ABOUT relationship." ;
    rdfs:subClassOf kgo:Relationship .

kgo:ORCID a owl:Class ;
    rdfs:label "ORCID" ;
    rdfs:comment "An ORCID identifier resource." ;
    rdfs:subClassOf kgo:Entity .

kgo:SameAsRelationship a owl:Class ;
    rdfs:label "same as relationship" ;
    rdfs:comment "Represents a SAME_AS relationship." ;
    rdfs:subClassOf kgo:Relationship .

kgo:SubOrganizationRelationship a owl:Class ;
    rdfs:label "sub organization relationship" ;
    rdfs:comment "Represents a SUB_ORGANIZATION relationship." ;
    rdfs:subClassOf kgo:Relationship .

kgo:University a owl:Class ;
    rdfs:label "University" ;
    rdfs:comment "A university." ;
    rdfs:subClassOf kgo:Entity,
        schema:CollegeOrUniversity .

kgo:Wikidata a owl:Class ;
    rdfs:label "Wikidata" ;
    rdfs:comment "A Wikidata entity." ;
    rdfs:subClassOf kgo:Entity .

kgo:awardNumber a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "award number" ;
    rdfs:comment "Ontology property 'award number'." ;
    rdfs:domain kgo:Grant ;
    rdfs:range xsd:string .

kgo:datePublished a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "date published" ;
    rdfs:comment "Ontology property 'date published'." ;
    rdfs:domain kgo:Publication ;
    rdfs:range xsd:date .

kgo:description a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "description" ;
    rdfs:comment "Ontology property 'description'." ;
    rdfs:domain kgo:ConceptScheme ;
    rdfs:range xsd:string .

kgo:email a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "email" ;
    rdfs:comment "Ontology property 'email'." ;
    rdfs:domain kgo:Faculty ;
    rdfs:range xsd:string .

kgo:endDate a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "end date" ;
    rdfs:comment "Ontology property 'end date'." ;
    rdfs:domain kgo:Grant ;
    rdfs:range xsd:date .

kgo:identifier a owl:DatatypeProperty ;
    rdfs:label "identifier" ;
    rdfs:comment "Unique identifier for the resource." ;
    rdfs:range xsd:string .

kgo:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:comment "Human-readable name of the resource." ;
    rdfs:range xsd:string .

kgo:netid a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "netid" ;
    rdfs:comment "Ontology property 'netid'." ;
    rdfs:domain kgo:Faculty ;
    rdfs:range xsd:string .

kgo:rank a owl:DatatypeProperty ;
    rdfs:label "rank" ;
    rdfs:comment "Ontology property 'rank'." ;
    rdfs:domain kgo:Faculty ;
    rdfs:range xsd:string .

kgo:source a owl:ObjectProperty ;
    rdfs:label "source" ;
    rdfs:comment "The source entity of a relationship." ;
    rdfs:domain kgo:Relationship ;
    rdfs:range kgo:Entity .

kgo:sponsor a owl:DatatypeProperty ;
    rdfs:label "sponsor" ;
    rdfs:comment "Ontology property 'sponsor'." ;
    rdfs:domain kgo:Grant ;
    rdfs:range xsd:string .

kgo:startDate a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "start date" ;
    rdfs:comment "Ontology property 'start date'." ;
    rdfs:domain kgo:Grant ;
    rdfs:range xsd:date .

kgo:target a owl:ObjectProperty ;
    rdfs:label "target" ;
    rdfs:comment "The target entity of a relationship." ;
    rdfs:domain kgo:Relationship ;
    rdfs:range kgo:Entity .

kgo:title a owl:DatatypeProperty ;
    rdfs:label "title" ;
    rdfs:comment "Title of the resource." ;
    rdfs:range xsd:string .

kgo:uri a owl:DatatypeProperty ;
    rdfs:label "uri" ;
    rdfs:comment "Canonical URI identifying the resource." ;
    rdfs:range xsd:anyURI .

kgo:venue a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "venue" ;
    rdfs:comment "Ontology property 'venue'." ;
    rdfs:domain kgo:Publication ;
    rdfs:range xsd:string .

kgo:ConceptScheme a owl:Class ;
    rdfs:label "ConceptScheme" ;
    rdfs:comment "A controlled vocabulary of research concepts." ;
    rdfs:subClassOf skos:ConceptScheme,
        kgo:Entity .

kgo:Publication a owl:Class ;
    rdfs:label "Publication" ;
    rdfs:comment "A scholarly publication." ;
    rdfs:subClassOf kgo:Entity,
        schema:ScholarlyArticle .

kgo:Faculty a owl:Class ;
    rdfs:label "Faculty" ;
    rdfs:comment "A faculty member within the College of Engineering." ;
    rdfs:subClassOf kgo:Entity,
        schema:Person .

kgo:Grant a owl:Class ;
    rdfs:label "Grant" ;
    rdfs:comment "A sponsored research award." ;
    rdfs:subClassOf kgo:Entity .

kgo:Entity a owl:Class ;
    rdfs:label "Entity" ;
    rdfs:comment "Base class for entity instances in the knowledge graph." .

kgo:Relationship a owl:Class ;
    rdfs:label "Relationship" ;
    rdfs:comment "Base class for relationship instances in the n-ary ontology." .

